# ===========================
# Governance Stack Environment Variables
# Copy this file to .env and fill in your values
# ===========================

# ===========================
# Apibara Configuration
# ===========================
# Get DNA token from https://app.apibara.com/
DNA_TOKEN=dna_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
APIBARA_URL=mainnet.starknet.a5a.ch

# ===========================
# Network Configuration
# ===========================
NETWORK=mainnet

# ===========================
# Database Configuration
# ===========================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
GOVERNANCE_DB=mainnet
GOVERNANCE_DB_PORT=5432

# ===========================
# Governance Contract Addresses
# ===========================
# Governor contract address
GOVERNOR_ADDRESS=0x...
# Votes token (staked token) address
VOTES_TOKEN_ADDRESS=0x...

# ===========================
# Indexer Configuration
# ===========================
# Block number to start indexing from (0 = from beginning)
STARTING_CURSOR_BLOCK_NUMBER=0
# Logging level (debug, info, warn, error)
LOG_LEVEL=info
# Timeout for no blocks received (0 = disabled, recommended for governance)
NO_BLOCKS_TIMEOUT_MS=0

# ===========================
# API Configuration
# ===========================
API_PORT=4000
CORS_ORIGIN=*
# Cache TTLs in seconds
CACHE_TTL_PROPOSALS=120
CACHE_TTL_VOTES=60
CACHE_TTL_DELEGATES=300

# ===========================
# UI Configuration
# ===========================
# Note: UI is deployed separately (Vercel/Netlify)
# Configure VITE_API_URL in the UI deployment to point to your API
