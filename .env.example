# Postgres Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mainnet
POSTGRES_PORT=5432

# Network Configuration
NETWORK=mainnet

# Apibara Configuration
APIBARA_URL=https://mainnet.starknet.a5a.ch
DNA_TOKEN=your_dna_token_here

# Contract Addresses (replace with your actual addresses)
GOVERNOR_ADDRESS=0x...
VOTES_TOKEN_ADDRESS=0x...

# Indexer Configuration
STARTING_CURSOR_BLOCK_NUMBER=0
LOG_LEVEL=info
NO_BLOCKS_TIMEOUT_MS=120000

# PostgREST Configuration
POSTGREST_PORT=3000
POSTGREST_URL=http://localhost:3000

# UI Configuration
UI_PORT=8080
VITE_POSTGREST_URL=http://localhost:3000
