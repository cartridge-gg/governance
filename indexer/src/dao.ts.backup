import type { PoolClient } from "pg";
import { Client } from "pg";
import type { EventKey } from "./processor.ts";
import type {
  ProposalCreatedEvent,
  ProposalQueuedEvent,
  ProposalExecutedEvent,
  ProposalCanceledEvent,
  VoteCastEvent,
  VoteCastWithParamsEvent,
} from "./events/governor.ts";
import type {
  DelegateChangedEvent,
  DelegateVotesChangedEvent,
} from "./events/votes.ts";

// Data access object that manages inserts/deletes
export class DAO {
  private pg: Client | PoolClient;

  constructor(pg: Client | PoolClient) {
    this.pg = pg;
  }

  public async beginTransaction(): Promise<void> {
    await this.pg.query("BEGIN");
  }

  public async commitTransaction(): Promise<void> {
    await this.pg.query("COMMIT");
  }

  public async initializeSchema() {
    await this.beginTransaction();
    await this.createSchema();
    const cursor = await this.loadCursor();
    // we need to clear anything that was potentially inserted as pending before starting
    if (cursor) {
      await this.deleteOldBlockNumbers(Number(cursor.orderKey) + 1);
    }
    await this.commitTransaction();
    return cursor;
  }

  private async createSchema(): Promise<void> {
    await this.pg.query(`
        CREATE TABLE IF NOT EXISTS cursor
        (
            id           INT         NOT NULL UNIQUE CHECK (id = 1), -- only one row.
            order_key    BIGINT      NOT NULL,
            unique_key   bytea       NOT NULL,
            last_updated timestamptz NOT NULL
        );

        CREATE TABLE IF NOT EXISTS blocks
        (
            -- int4 blocks represents over a thousand years at 12 second blocks
            number   int4        NOT NULL PRIMARY KEY,
            hash     NUMERIC     NOT NULL,
            time     timestamptz NOT NULL,
            inserted timestamptz NOT NULL DEFAULT NOW()
        );
        CREATE INDEX IF NOT EXISTS idx_blocks_time ON blocks USING btree (time);
        CREATE UNIQUE INDEX IF NOT EXISTS idx_blocks_hash ON blocks USING btree (hash);

        CREATE TABLE IF NOT EXISTS pool_keys
        (
            key_hash     NUMERIC NOT NULL PRIMARY KEY,
            token0       NUMERIC NOT NULL,
            token1       NUMERIC NOT NULL,
            fee          NUMERIC NOT NULL,
            tick_spacing INT     NOT NULL,
            extension    NUMERIC NOT NULL
        );
        CREATE INDEX IF NOT EXISTS idx_pool_keys_token0 ON pool_keys USING btree (token0);
        CREATE INDEX IF NOT EXISTS idx_pool_keys_token1 ON pool_keys USING btree (token1);
        CREATE INDEX IF NOT EXISTS idx_pool_keys_token0_token1 ON pool_keys USING btree (token0, token1);
        CREATE INDEX IF NOT EXISTS idx_pool_keys_extension ON pool_keys USING btree (extension);

        -- all events reference an event id which contains the metadata of the event
        CREATE TABLE IF NOT EXISTS event_keys
        (
            id                int8 GENERATED ALWAYS AS (block_number * 4294967296 + transaction_index * 65536 + event_index) STORED PRIMARY KEY,
            transaction_hash  TEXT NOT NULL,
            block_number      int4    NOT NULL REFERENCES blocks (number) ON DELETE CASCADE,
            transaction_index int2    NOT NULL,
            event_index       int2    NOT NULL,
            emitter           NUMERIC NOT NULL
        );
        CREATE INDEX IF NOT EXISTS idx_event_keys_block_number_transaction_index_event_index ON event_keys USING btree (block_number, transaction_index, event_index);
        CREATE INDEX IF NOT EXISTS idx_event_keys_transaction_hash ON event_keys USING btree (transaction_hash);

        CREATE TABLE IF NOT EXISTS swaps
        (
            event_id         int8 REFERENCES event_keys (id) ON DELETE CASCADE PRIMARY KEY,

            locker           NUMERIC NOT NULL,
            pool_key_hash    NUMERIC NOT NULL REFERENCES pool_keys (key_hash),

            delta0           NUMERIC NOT NULL,
            delta1           NUMERIC NOT NULL,

            sqrt_ratio_after NUMERIC NOT NULL,
            tick_after       int4    NOT NULL,
            liquidity_after  NUMERIC NOT NULL
        );
        CREATE INDEX IF NOT EXISTS idx_swaps_pool_key_hash_event_id ON swaps USING btree (pool_key_hash, event_id);
        CREATE INDEX IF NOT EXISTS idx_swaps_pool_key_hash_event_id_desc ON swaps USING btree (pool_key_hash, event_id DESC) INCLUDE (sqrt_ratio_after, tick_after, liquidity_after);

        CREATE TABLE IF NOT EXISTS proposals
        (
            event_id     int8 REFERENCES event_keys (id) ON DELETE CASCADE PRIMARY KEY,

            proposal_id  NUMERIC NOT NULL,
            proposer     NUMERIC NOT NULL,
            vote_start   BIGINT  NOT NULL,
            vote_end     BIGINT  NOT NULL,
            description  TEXT    NOT NULL
        );
        CREATE UNIQUE INDEX IF NOT EXISTS idx_proposals_proposal_id ON proposals USING btree (proposal_id);
        CREATE INDEX IF NOT EXISTS idx_proposals_proposer ON proposals USING btree (proposer);

        CREATE TABLE IF NOT EXISTS proposal_calls
        (
            proposal_id  NUMERIC   NOT NULL REFERENCES proposals (proposal_id) ON DELETE CASCADE,
            call_index   int2      NOT NULL,
            to_address   NUMERIC   NOT NULL,
            selector     NUMERIC   NOT NULL,
            calldata     NUMERIC[] NOT NULL,
            PRIMARY KEY (proposal_id, call_index)
        );

        CREATE TABLE IF NOT EXISTS proposal_signatures
        (
            proposal_id      NUMERIC   NOT NULL REFERENCES proposals (proposal_id) ON DELETE CASCADE,
            signature_index  int2      NOT NULL,
            signature        NUMERIC[] NOT NULL,
            PRIMARY KEY (proposal_id, signature_index)
        );

        CREATE TABLE IF NOT EXISTS proposal_queued
        (
            event_id     int8 REFERENCES event_keys (id) ON DELETE CASCADE PRIMARY KEY,

            proposal_id  NUMERIC NOT NULL,
            eta_seconds  BIGINT  NOT NULL
        );
        CREATE UNIQUE INDEX IF NOT EXISTS idx_proposal_queued_proposal_id ON proposal_queued USING btree (proposal_id);

        CREATE TABLE IF NOT EXISTS proposal_executed
        (
            event_id     int8 REFERENCES event_keys (id) ON DELETE CASCADE PRIMARY KEY,

            proposal_id  NUMERIC NOT NULL
        );
        CREATE UNIQUE INDEX IF NOT EXISTS idx_proposal_executed_proposal_id ON proposal_executed USING btree (proposal_id);

        CREATE TABLE IF NOT EXISTS proposal_canceled
        (
            event_id     int8 REFERENCES event_keys (id) ON DELETE CASCADE PRIMARY KEY,

            proposal_id  NUMERIC NOT NULL
        );
        CREATE UNIQUE INDEX IF NOT EXISTS idx_proposal_canceled_proposal_id ON proposal_canceled USING btree (proposal_id);

        CREATE TABLE IF NOT EXISTS votes
        (
            event_id     int8 REFERENCES event_keys (id) ON DELETE CASCADE PRIMARY KEY,

            proposal_id  NUMERIC   NOT NULL,
            voter        NUMERIC   NOT NULL,
            support      int2      NOT NULL,
            weight       NUMERIC   NOT NULL,
            reason       TEXT      NOT NULL,
            params       NUMERIC[] NULL
        );
        CREATE INDEX IF NOT EXISTS idx_votes_proposal_id ON votes USING btree (proposal_id);
        CREATE INDEX IF NOT EXISTS idx_votes_voter ON votes USING btree (voter);
        CREATE INDEX IF NOT EXISTS idx_votes_proposal_voter ON votes USING btree (proposal_id, voter);

        CREATE TABLE IF NOT EXISTS delegate_changed
        (
            event_id      int8 REFERENCES event_keys (id) ON DELETE CASCADE PRIMARY KEY,

            delegator     NUMERIC NOT NULL,
            from_delegate NUMERIC NOT NULL,
            to_delegate   NUMERIC NOT NULL
        );
        CREATE INDEX IF NOT EXISTS idx_delegate_changed_delegator ON delegate_changed USING btree (delegator);
        CREATE INDEX IF NOT EXISTS idx_delegate_changed_to_delegate ON delegate_changed USING btree (to_delegate);
        CREATE INDEX IF NOT EXISTS idx_delegate_changed_from_delegate ON delegate_changed USING btree (from_delegate);

        CREATE TABLE IF NOT EXISTS delegate_votes_changed
        (
            event_id       int8 REFERENCES event_keys (id) ON DELETE CASCADE PRIMARY KEY,

            delegate       NUMERIC NOT NULL,
            previous_votes NUMERIC NOT NULL,
            new_votes      NUMERIC NOT NULL
        );
        CREATE INDEX IF NOT EXISTS idx_delegate_votes_changed_delegate ON delegate_votes_changed USING btree (delegate);

        -- Token metadata for price calculations
        CREATE TABLE IF NOT EXISTS token_metadata
        (
            address  NUMERIC NOT NULL PRIMARY KEY,
            symbol   TEXT    NOT NULL,
            decimals int2    NOT NULL
        );
        CREATE INDEX IF NOT EXISTS idx_token_metadata_symbol ON token_metadata USING btree (symbol);

        -- Oracle snapshot events for price feeds
        CREATE TABLE IF NOT EXISTS oracle_snapshots
        (
            event_id         int8 REFERENCES event_keys (id) ON DELETE CASCADE PRIMARY KEY,

            timestamp_u64    BIGINT  NOT NULL,
            tick_cumulative  NUMERIC NOT NULL,
            tick_sign        int2    NOT NULL, -- 0 for positive, 1 for negative
            token0           NUMERIC NOT NULL,
            token1           NUMERIC NOT NULL
        );
        CREATE INDEX IF NOT EXISTS idx_oracle_snapshots_token0_token1_timestamp ON oracle_snapshots USING btree (token0, token1, timestamp_u64);
        CREATE INDEX IF NOT EXISTS idx_oracle_snapshots_tokens ON oracle_snapshots USING btree (token0, token1);

        -- Utility function to convert numeric addresses to hex strings
        CREATE OR REPLACE FUNCTION numeric_to_hex(num NUMERIC) RETURNS TEXT
            IMMUTABLE
            LANGUAGE plpgsql
        AS
        $$
        DECLARE
            hex       TEXT;
            remainder NUMERIC;
        BEGIN
            hex := '';
            LOOP
                IF num = 0 THEN
                    EXIT;
                END IF;
                remainder := num % 16;
                hex := SUBSTRING('0123456789abcdef' FROM (remainder::INT + 1) FOR 1) || hex;
                num := (num - remainder) / 16;
            END LOOP;
            RETURN '0x' || hex;
        END;
        $$;

        -- View to get current delegation state for each delegator
        CREATE OR REPLACE VIEW current_delegations_view AS
        (
        WITH latest_delegation_events AS (
            SELECT
                delegator,
                to_delegate,
                event_id,
                ROW_NUMBER() OVER (PARTITION BY delegator ORDER BY event_id DESC) AS rn
            FROM delegate_changed
        )
        SELECT
            delegator::TEXT AS delegator,
            to_delegate::TEXT AS current_delegate,
            numeric_to_hex(delegator) AS delegator_hex,
            numeric_to_hex(to_delegate) AS current_delegate_hex
        FROM latest_delegation_events
        WHERE rn = 1
        );

        -- View to get current voting power for each delegate
        -- Drop first to allow column type changes
        DROP VIEW IF EXISTS current_delegate_votes_view CASCADE;
        CREATE VIEW current_delegate_votes_view AS
        (
        WITH latest_votes_events AS (
            SELECT
                delegate,
                new_votes,
                event_id,
                ROW_NUMBER() OVER (PARTITION BY delegate ORDER BY event_id DESC) AS rn
            FROM delegate_votes_changed
        )
        SELECT
            delegate::TEXT AS delegate,
            '0x' || LPAD(SUBSTRING(numeric_to_hex(new_votes) FROM 3), 64, '0') AS current_votes,
            numeric_to_hex(delegate) AS delegate_hex
        FROM latest_votes_events
        WHERE rn = 1
        );

        -- View to get total delegated votes across all delegates
        CREATE OR REPLACE VIEW total_delegated_votes_view AS
        WITH latest_votes_events AS (
            SELECT
                delegate,
                new_votes,
                event_id,
                ROW_NUMBER() OVER (PARTITION BY delegate ORDER BY event_id DESC) AS rn
            FROM delegate_votes_changed
        )
        SELECT
            COALESCE(SUM(new_votes), 0)::TEXT AS total_votes
        FROM latest_votes_events
        WHERE rn = 1;

        -- API-friendly views that cast NUMERIC to TEXT to preserve precision in JSON
        -- This prevents JavaScript number overflow for large Starknet addresses and values

        CREATE OR REPLACE VIEW proposals_api AS
        SELECT
            event_id,
            proposal_id::TEXT,
            proposer::TEXT,
            vote_start,
            vote_end,
            description,
            numeric_to_hex(proposal_id) AS proposal_id_hex,
            numeric_to_hex(proposer) AS proposer_hex
        FROM proposals;

        CREATE OR REPLACE VIEW proposal_calls_api AS
        SELECT
            proposal_id::TEXT,
            call_index,
            to_address::TEXT,
            selector::TEXT,
            (SELECT json_agg(cd::TEXT) FROM unnest(calldata) AS cd) AS calldata,
            numeric_to_hex(proposal_id) AS proposal_id_hex,
            numeric_to_hex(to_address) AS to_address_hex,
            numeric_to_hex(selector) AS selector_hex
        FROM proposal_calls;

        DROP VIEW IF EXISTS votes_api CASCADE;
        CREATE VIEW votes_api AS
        SELECT
            event_id,
            proposal_id::TEXT,
            voter::TEXT,
            support,
            weight::TEXT,
            '0x' || LPAD(REPLACE(weight::TEXT, '.', ''), 64, '0') AS weight_sortable,
            reason,
            (SELECT json_agg(p::TEXT) FROM unnest(params) AS p) AS params,
            numeric_to_hex(proposal_id) AS proposal_id_hex,
            numeric_to_hex(voter) AS voter_hex
        FROM votes;

        -- Materialized views for price calculations
        -- Step 1: Deduplicate oracle snapshots by timestamp
        CREATE MATERIALIZED VIEW IF NOT EXISTS oracle_snapshots_deduped AS
        WITH ranked_snapshots AS (
            SELECT
                os.*,
                ek.block_number,
                b.time AS block_time,
                ROW_NUMBER() OVER (PARTITION BY os.token0, os.token1, os.timestamp_u64 ORDER BY ek.block_number DESC) AS rn
            FROM oracle_snapshots os
            JOIN event_keys ek ON os.event_id = ek.id
            JOIN blocks b ON ek.block_number = b.number
        )
        SELECT
            event_id,
            timestamp_u64,
            CASE
                WHEN tick_sign = 1 THEN -tick_cumulative::DOUBLE PRECISION
                ELSE tick_cumulative::DOUBLE PRECISION
            END AS tick_cumulative,
            token0,
            token1,
            block_time
        FROM ranked_snapshots
        WHERE rn = 1;
        CREATE INDEX IF NOT EXISTS idx_oracle_deduped_tokens_ts ON oracle_snapshots_deduped (token0, token1, timestamp_u64);

        -- Step 2: Calculate tick differences and time-weighted average ticks
        CREATE MATERIALIZED VIEW IF NOT EXISTS oracle_avg_ticks AS
        WITH diffs AS (
            SELECT
                token0,
                token1,
                block_time,
                tick_cumulative - LAG(tick_cumulative) OVER (PARTITION BY token0, token1 ORDER BY timestamp_u64) AS d_tick,
                timestamp_u64 - LAG(timestamp_u64) OVER (PARTITION BY token0, token1 ORDER BY timestamp_u64) AS dt
            FROM oracle_snapshots_deduped
        )
        SELECT
            token0,
            token1,
            block_time,
            d_tick / NULLIF(dt::DOUBLE PRECISION, 0) AS avg_tick
        FROM diffs
        WHERE dt BETWEEN 1 AND 86400;
        CREATE INDEX IF NOT EXISTS idx_oracle_avg_ticks_time ON oracle_avg_ticks (block_time);
        CREATE INDEX IF NOT EXISTS idx_oracle_avg_ticks_tokens ON oracle_avg_ticks (token0, token1);

        -- Step 3: Convert ticks to prices for each token pair
        CREATE MATERIALIZED VIEW IF NOT EXISTS pair_prices AS
        SELECT
            DATE_TRUNC('hour', t.block_time) AS hour,
            t.token0,
            t.token1,
            POWER(1.000001, t.avg_tick) * POWER(10, (tm0.decimals - tm1.decimals)) AS price_real
        FROM oracle_avg_ticks t
        JOIN token_metadata tm0 ON tm0.address = t.token0
        JOIN token_metadata tm1 ON tm1.address = t.token1;
        CREATE INDEX IF NOT EXISTS idx_pair_prices_hour ON pair_prices (hour);
        CREATE INDEX IF NOT EXISTS idx_pair_prices_tokens ON pair_prices (token0, token1);

        -- Step 4: Calculate EKUBO/USD price
        -- Dynamically looks up EKUBO and USDC from token_metadata by symbol
        CREATE MATERIALIZED VIEW IF NOT EXISTS ekubo_usd_prices AS
        WITH token_addresses AS (
            SELECT
                (SELECT address FROM token_metadata WHERE symbol = 'EKUBO') AS ekubo_address,
                (SELECT address FROM token_metadata WHERE symbol = 'USDC') AS usdc_address
        )
        SELECT
            hour,
            CASE
                WHEN token0 = (SELECT ekubo_address FROM token_addresses) THEN price_real
                ELSE 1 / price_real
            END AS usd_per_ekubo
        FROM pair_prices, token_addresses
        WHERE
            (token0 = (SELECT ekubo_address FROM token_addresses)
             AND token1 = (SELECT usdc_address FROM token_addresses))
            OR
            (token1 = (SELECT ekubo_address FROM token_addresses)
             AND token0 = (SELECT usdc_address FROM token_addresses));
        CREATE INDEX IF NOT EXISTS idx_ekubo_usd_hour ON ekubo_usd_prices (hour);

        -- Step 5: Calculate token prices in EKUBO
        -- Dynamically looks up EKUBO from token_metadata by symbol
        CREATE MATERIALIZED VIEW IF NOT EXISTS token_ekubo_prices AS
        WITH ekubo_token AS (
            SELECT address AS ekubo_address FROM token_metadata WHERE symbol = 'EKUBO'
        )
        SELECT
            hour,
            CASE
                WHEN token0 = (SELECT ekubo_address FROM ekubo_token) THEN token1
                ELSE token0
            END AS token_address,
            CASE
                WHEN token0 = (SELECT ekubo_address FROM ekubo_token) THEN 1 / price_real
                ELSE price_real
            END AS token_per_ekubo
        FROM pair_prices, ekubo_token
        WHERE token0 = (SELECT ekubo_address FROM ekubo_token)
           OR token1 = (SELECT ekubo_address FROM ekubo_token);
        CREATE INDEX IF NOT EXISTS idx_token_ekubo_hour ON token_ekubo_prices (hour);
        CREATE INDEX IF NOT EXISTS idx_token_ekubo_token ON token_ekubo_prices (token_address);

        -- Step 6: Final token USD prices
        CREATE MATERIALIZED VIEW IF NOT EXISTS token_usd_prices AS
        SELECT
            t.hour,
            t.token_address,
            t.token_per_ekubo * e.usd_per_ekubo AS usd_per_token
        FROM token_ekubo_prices t
        JOIN ekubo_usd_prices e ON t.hour = e.hour;
        CREATE INDEX IF NOT EXISTS idx_token_usd_hour ON token_usd_prices (hour);
        CREATE INDEX IF NOT EXISTS idx_token_usd_token ON token_usd_prices (token_address);

        -- API view for daily average token prices
        CREATE OR REPLACE VIEW token_prices_daily_api AS
        SELECT
            DATE_TRUNC('day', hour) AS day,
            m.symbol AS token_symbol,
            token_usd_prices.token_address::TEXT AS token_address,
            numeric_to_hex(token_usd_prices.token_address) AS token_address_hex,
            AVG(usd_per_token) AS avg_price_usd
        FROM token_usd_prices
        JOIN token_metadata m ON token_usd_prices.token_address = m.address
        GROUP BY 1, 2, token_usd_prices.token_address
        ORDER BY day DESC;

        -- API view for hourly token prices
        CREATE OR REPLACE VIEW token_prices_hourly_api AS
        SELECT
            hour,
            m.symbol AS token_symbol,
            token_address::TEXT,
            numeric_to_hex(token_address) AS token_address_hex,
            usd_per_token
        FROM token_usd_prices
        JOIN token_metadata m ON token_usd_prices.token_address = m.address
        ORDER BY hour DESC;

        -- Materialized view: Swaps with USD values
        CREATE MATERIALIZED VIEW IF NOT EXISTS swaps_with_usd AS
        SELECT
            s.event_id,
            ek.block_number,
            b.time AS block_time,
            DATE_TRUNC('hour', b.time) AS hour,
            ek.transaction_hash,
            s.locker,
            pk.token0,
            pk.token1,
            tm0.symbol AS token0_symbol,
            tm1.symbol AS token1_symbol,
            tm0.decimals AS token0_decimals,
            tm1.decimals AS token1_decimals,
            s.delta0,
            s.delta1,
            -- Convert delta amounts to decimal (divide by 10^decimals)
            s.delta0::DOUBLE PRECISION / POWER(10, tm0.decimals) AS delta0_decimal,
            s.delta1::DOUBLE PRECISION / POWER(10, tm1.decimals) AS delta1_decimal,
            -- Join with hourly prices to get USD values
            COALESCE(p0.usd_per_token, 0) AS token0_price_usd,
            COALESCE(p1.usd_per_token, 0) AS token1_price_usd,
            -- Calculate USD values (absolute value of delta * price)
            ABS(s.delta0::DOUBLE PRECISION / POWER(10, tm0.decimals)) * COALESCE(p0.usd_per_token, 0) AS delta0_usd,
            ABS(s.delta1::DOUBLE PRECISION / POWER(10, tm1.decimals)) * COALESCE(p1.usd_per_token, 0) AS delta1_usd
        FROM swaps s
        JOIN event_keys ek ON s.event_id = ek.id
        JOIN blocks b ON ek.block_number = b.number
        JOIN pool_keys pk ON s.pool_key_hash = pk.key_hash
        JOIN token_metadata tm0 ON pk.token0 = tm0.address
        JOIN token_metadata tm1 ON pk.token1 = tm1.address
        LEFT JOIN token_usd_prices p0 ON pk.token0 = p0.token_address AND DATE_TRUNC('hour', b.time) = p0.hour
        LEFT JOIN token_usd_prices p1 ON pk.token1 = p1.token_address AND DATE_TRUNC('hour', b.time) = p1.hour;
        CREATE INDEX IF NOT EXISTS idx_swaps_with_usd_block_time ON swaps_with_usd (block_time);
        CREATE INDEX IF NOT EXISTS idx_swaps_with_usd_token0 ON swaps_with_usd (token0);
        CREATE INDEX IF NOT EXISTS idx_swaps_with_usd_token1 ON swaps_with_usd (token1);
        CREATE INDEX IF NOT EXISTS idx_swaps_with_usd_token0_symbol ON swaps_with_usd (token0_symbol);
        CREATE INDEX IF NOT EXISTS idx_swaps_with_usd_token1_symbol ON swaps_with_usd (token1_symbol);

        -- API view: Swaps with USD values
        CREATE OR REPLACE VIEW swaps_with_usd_api AS
        SELECT
            event_id,
            block_number,
            block_time,
            transaction_hash,
            transaction_hash AS transaction_hash_hex,
            locker::TEXT,
            numeric_to_hex(locker) AS locker_hex,
            token0::TEXT,
            numeric_to_hex(token0) AS token0_hex,
            token1::TEXT,
            numeric_to_hex(token1) AS token1_hex,
            token0_symbol,
            token1_symbol,
            delta0::TEXT,
            delta1::TEXT,
            delta0_decimal,
            delta1_decimal,
            token0_price_usd,
            token1_price_usd,
            delta0_usd,
            delta1_usd,
            -- Total swap value in USD (using the larger of the two deltas)
            GREATEST(delta0_usd, delta1_usd) AS swap_value_usd
        FROM swaps_with_usd;

        -- API view: Aggregate stats for ticket purchases (swaps involving TICKET or DTICKET token)
        CREATE OR REPLACE VIEW ticket_purchase_stats_api AS
        SELECT
            COUNT(*) AS total_purchases,
            SUM(GREATEST(delta0_usd, delta1_usd)) AS total_volume_usd,
            AVG(GREATEST(delta0_usd, delta1_usd)) AS avg_purchase_usd,
            MIN(GREATEST(delta0_usd, delta1_usd)) AS min_purchase_usd,
            MAX(GREATEST(delta0_usd, delta1_usd)) AS max_purchase_usd,
            COUNT(DISTINCT locker) AS unique_buyers,
            MIN(block_time) AS first_purchase_time,
            MAX(block_time) AS last_purchase_time
        FROM swaps_with_usd
        WHERE token0_symbol IN ('TICKET', 'DTICKET') OR token1_symbol IN ('TICKET', 'DTICKET');

        -- API view: Daily ticket purchase volume
        CREATE OR REPLACE VIEW ticket_purchases_daily_api AS
        SELECT
            DATE_TRUNC('day', block_time) AS day,
            COUNT(*) AS purchases,
            SUM(GREATEST(delta0_usd, delta1_usd)) AS volume_usd,
            AVG(GREATEST(delta0_usd, delta1_usd)) AS avg_purchase_usd,
            COUNT(DISTINCT locker) AS unique_buyers
        FROM swaps_with_usd
        WHERE token0_symbol IN ('TICKET', 'DTICKET') OR token1_symbol IN ('TICKET', 'DTICKET')
        GROUP BY 1
        ORDER BY day DESC;
    `);
  }

  /**
   * Refresh all materialized views for price calculations
   * Call this periodically or after inserting oracle snapshot events
   * to update the price data
   */
  public async refreshAnalyticalTables() {
    // Refresh materialized views in dependency order
    // Note: Not using CONCURRENTLY since these views don't have unique indexes
    // and we're already in a sequential process
    await this.pg.query("REFRESH MATERIALIZED VIEW oracle_snapshots_deduped;");
    await this.pg.query("REFRESH MATERIALIZED VIEW oracle_avg_ticks;");
    await this.pg.query("REFRESH MATERIALIZED VIEW pair_prices;");
    await this.pg.query("REFRESH MATERIALIZED VIEW ekubo_usd_prices;");
    await this.pg.query("REFRESH MATERIALIZED VIEW token_ekubo_prices;");
    await this.pg.query("REFRESH MATERIALIZED VIEW token_usd_prices;");
    // Refresh swaps with USD values (depends on token_usd_prices)
    await this.pg.query("REFRESH MATERIALIZED VIEW swaps_with_usd;");
  }

  public async refreshOperationalMaterializedView() {
    // No-op for governance-only indexing
  }

  private async loadCursor(): Promise<
    | {
        orderKey: bigint;
        uniqueKey: `0x${string}`;
      }
    | { orderKey: bigint }
    | null
  > {
    const { rows } = await this.pg.query({
      text: `SELECT order_key, unique_key
                   FROM cursor
                   WHERE id = 1;`,
    });
    if (rows.length === 1) {
      const { order_key, unique_key } = rows[0];

      if (BigInt(unique_key) === 0n) {
        return {
          orderKey: BigInt(order_key),
        };
      } else {
        return {
          orderKey: BigInt(order_key),
          uniqueKey: `0x${BigInt(unique_key).toString(16)}`,
        };
      }
    } else {
      return null;
    }
  }

  public async writeCursor(cursor: { orderKey: bigint; uniqueKey?: string }) {
    await this.pg.query({
      text: `
          INSERT INTO cursor (id, order_key, unique_key, last_updated)
          VALUES (1, $1, $2, NOW())
          ON CONFLICT (id) DO UPDATE SET order_key    = excluded.order_key,
                                         unique_key   = excluded.unique_key,
                                         last_updated = NOW();
      `,
      values: [cursor.orderKey, BigInt(cursor.uniqueKey ?? 0)],
    });
  }

  public async insertBlock({
    number,
    hash,
    time,
  }: {
    number: bigint;
    hash: bigint;
    time: Date;
  }) {
    await this.pg.query({
      text: `INSERT INTO blocks (number, hash, time)
                   VALUES ($1, $2, $3);`,
      values: [number, hash, time],
    });
  }

  /**
   * Deletes all the blocks equal to or greater than the given block number, cascades to all the other tables.
   * @param invalidatedBlockNumber the block number for which data in the database should be removed
   */
  public async deleteOldBlockNumbers(invalidatedBlockNumber: number) {
    const { rowCount } = await this.pg.query({
      text: `
                DELETE
                FROM blocks
                WHERE number >= $1;
            `,
      values: [invalidatedBlockNumber],
    });
    if (rowCount === null) throw new Error("Null row count after delete");
    return rowCount;
  }

  // =============================================================================
  // GOVERNANCE EVENT INSERTION METHODS
  // =============================================================================

  async insertProposalCreatedEvent(
    parsed: ProposalCreatedEvent,
    key: EventKey
  ) {
    const query =
      parsed.calls.length > 0
        ? `
                        WITH inserted_event AS (
                            INSERT INTO event_keys (block_number, transaction_index, event_index, transaction_hash, emitter)
                                VALUES ($1, $2, $3, $4, $5)
                                RETURNING id),
                             inserted_proposal AS (
                                 INSERT
                                     INTO proposals
                                         (event_id, proposal_id, proposer, vote_start, vote_end, description)
                                         VALUES ((SELECT id FROM inserted_event), $6, $7, $8, $9, $10))
                        INSERT
                        INTO proposal_calls (proposal_id, call_index, to_address, selector, calldata)
                        VALUES
                        ${parsed.calls
                          .map(
                            (call, ix) =>
                              `($6, ${ix}, ${call.to}, ${
                                call.selector
                              }, '{${call.calldata
                                .map((c) => c.toString())
                                .join(",")}}')`
                          )
                          .join(",")};
                `
        : `
                        WITH inserted_event AS (
                            INSERT INTO event_keys (block_number, transaction_index, event_index, transaction_hash, emitter)
                                VALUES ($1, $2, $3, $4, $5)
                                RETURNING id)
                        INSERT
                        INTO proposals
                            (event_id, proposal_id, proposer, vote_start, vote_end, description)
                        VALUES ((SELECT id FROM inserted_event), $6, $7, $8, $9, $10);
                `;
    await this.pg.query({
      text: query,
      values: [
        key.blockNumber,
        key.transactionIndex,
        key.eventIndex,
        key.transactionHash,
        key.emitter,
        parsed.proposal_id,
        parsed.proposer,
        parsed.vote_start,
        parsed.vote_end,
        // postgres does not support null characters
        parsed.description.replaceAll("\u0000", "?"),
      ],
    });

    // Insert signatures if present
    if (parsed.signatures.length > 0) {
      const signatureValues = parsed.signatures
        .map(
          (sig, ix) =>
            `($6, ${ix}, '{${sig.map((s) => s.toString()).join(",")}}')`
        )
        .join(",");

      await this.pg.query({
        text: `
          INSERT INTO proposal_signatures (proposal_id, signature_index, signature)
          VALUES ${signatureValues};
        `,
        values: [
          key.blockNumber,
          key.transactionIndex,
          key.eventIndex,
          key.transactionHash,
          key.emitter,
          parsed.proposal_id,
        ],
      });
    }
  }

