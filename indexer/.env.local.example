# Governance contracts
GOVERNOR_ADDRESS="0x0..."
VOTES_TOKEN_ADDRESS="0x0..."

# Ekubo and Oracle contracts for price data
EKUBO_ADDRESS="0x0..."
ORACLE_ADDRESS="0x0..."

STARTING_CURSOR_BLOCK_NUMBER="0"

NETWORK="sepolia"

