# Token metadata for price calculations (JSON array)
# Required tokens: EKUBO and USDC for USD pricing
# Format: [{"address":"0x...","symbol":"TOKEN","decimals":18},...]
# Example:
TOKEN_METADATA='[{"address":"0x075afe6402ad5a5c20dd25e10ec3b3986acaa647b77e4ae24b0cbc9a54a27a87","symbol":"EKUBO","decimals":18},{"address":"0x053c91253bc9682c04929ca02ed00b3e423f6710d2ee7e0d5ebb06f3ecf368a8","symbol":"USDC","decimals":6},{"address":"0x035f581b050a39958b7188ab5c75daaa1f9d3571a0c032203038c898663f31f8","symbol":"TICKET","decimals":18},{"address":"0x00c530f2c0aa4c16a0806365b0898499fba372e5df7a7172dc6fe9ba777e8007","symbol":"SURVIVOR","decimals":18},{"address":"0x0124aeb495b947201f5fac96fd1138e326ad86195b98df6dec9009158a533b49","symbol":"LORDS","decimals":18},{"address":"0x04718f5a0fc34cc1af16a1cdee98ffb20c31f5cd61d6ab07201858f4287c938d","symbol":"STRK","decimals":18}]'