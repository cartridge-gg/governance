# API for governance data
VITE_API_URL=http://localhost:4000

# Voyager API Configuration
# You need either a proxy URL (Option 1) or an API key (Option 2)

# Option 1: Use proxy (recommended for production to hide API key)
# If set, proxy will be used and VITE_VOYAGER_API_KEY is not needed
# VITE_VOYAGER_PROXY_URL=https://your-proxy.com

# Option 2: Direct API access (requires API key from Voyager)
# Get your API key from https://voyager.online
VITE_VOYAGER_API_KEY=
VITE_VOYAGER_API_BASE_URL=https://api.voyager.online/beta
