PORT=4000

# Environment (development|production)
# In development mode, localhost origins are automatically allowed
NODE_ENV=development

# Governance database
GOVERNANCE_DB_URL=postgresql://postgres:postgres@localhost:5432/mainnet

# CORS - Comma-separated list of allowed origins
# Examples:
#   Development: CORS_ORIGIN=* (allow all)
#   Production: CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
# Note: localhost is auto-allowed in development mode
CORS_ORIGIN=*

# Cache TTLs (in seconds)
CACHE_TTL_PROPOSALS=120
CACHE_TTL_VOTES=60
CACHE_TTL_DELEGATES=300
